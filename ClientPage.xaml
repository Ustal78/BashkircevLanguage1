<Page x:Class="BashkircevLanguage.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BashkircevLanguage"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClientPage" FontFamily="Comic Sans MS">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <StackPanel Orientation="Horizontal" Margin="10" Grid.Row="0">

            <TextBlock Text="Поиск:" VerticalAlignment="Center"/>
            <TextBox Name="SearchBox" Width="200" Height="20" Margin="5" TextChanged="SearchBox_TextChanged"/>

            <TextBlock Text="Пол:" VerticalAlignment="Center" Height="20"/>
            <ComboBox Name="FilterCombo" Width="120" Margin="5" Height="20" SelectionChanged="FilterCombo_SelectionChanged"/>

            <TextBlock Text="Сортировка:" VerticalAlignment="Center" Height="20"/>
            <ComboBox Name="SortCombo" Width="200" Margin="5" Height="20" SelectionChanged="SortCombo_SelectionChanged">
                <ComboBoxItem Content="нет"/>
                <ComboBoxItem Content="по фамилии (А-Я)"/>
                <ComboBoxItem Content="по последнему посещению"/>
                <ComboBoxItem Content="по количеству посещений"/>
            </ComboBox>

        </StackPanel>

        <ListView Name="ClientListView" Grid.Row="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <ColumnDefinition Width="185"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Image Width="170" Height="170" Grid.Row="0" Stretch="Uniform" HorizontalAlignment="Center" Grid.RowSpan="4">
                            <Image.Source>
                                <Binding Path="PhotoPath"></Binding>
                            </Image.Source>
                        </Image>
                        <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="{Binding FirstName}" FontSize="20"></TextBlock>
                            <TextBlock Text=" "></TextBlock>
                            <TextBlock Text="{Binding LastName}" FontSize="20"></TextBlock>
                            <TextBlock Text=" "></TextBlock>
                            <TextBlock Text="{Binding Patronymic}" FontSize="20"></TextBlock>
                            <TextBlock Text=" ID: " FontSize="20"></TextBlock>
                            <TextBlock Text="{Binding ID}" FontSize="20"></TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal">
                            <TextBlock Text="Пол: " FontSize="20"></TextBlock>
                            <TextBlock Text="{Binding GenderCode}" FontSize="20"></TextBlock>
                            <TextBlock Text=" Дата рождения: " FontSize="20"></TextBlock>
                            <TextBlock Text="{Binding BirthdayString}" FontSize="20"></TextBlock>
                            <TextBlock Text=" Телефон: " FontSize="20"></TextBlock>
                            <TextBlock Text="{Binding Phone}" FontSize="20"></TextBlock>
                            <TextBlock Text=" Дата последнего посещения: " FontSize="20"/>
                            <TextBlock Text="{Binding LastVisitDateString}" FontSize="20"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="Email: " FontSize="20"></TextBlock>
                            <TextBlock Text="{Binding Email}" FontSize="20"></TextBlock>
                            <TextBlock Text=" Дата регистрации: " FontSize="20"></TextBlock>
                            <TextBlock Text="{Binding RegistrationDateString}" FontSize="20"></TextBlock>
                            <TextBlock Text=" Кол-во посещений: " FontSize="20"/>
                            <TextBlock Text="{Binding VisitCount}" FontSize="20"/>
                        </StackPanel>
                        <Button Grid.Column="2" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Content="Удалить" Click="DeleteBtn_Click"/>

                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="BorderBrush" Value="Black"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                    <Setter Property="Padding" Value="5"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBlock Text="Выводить по " VerticalAlignment="Center"/>
                <ComboBox Name="CountCombo" Width="70"
                      SelectionChanged="CountCombo_SelectionChanged">
                    <ComboBoxItem Content="10"/>
                    <ComboBoxItem Content="50"/>
                    <ComboBoxItem Content="200"/>
                    <ComboBoxItem Content="Все"/>
                </ComboBox>
            </StackPanel>

            <TextBlock Name="CountText" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="&lt;" Width="25" Click="PrevPage_Click"/>
                <StackPanel Name="PageNumbers" Orientation="Horizontal"/>
                <Button Content="&gt;" Width="25" Click="NextPage_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
